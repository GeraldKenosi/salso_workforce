import 'package:cloud_firestore/cloud_firestore.dart';
import 'package:firebase_auth/firebase_auth.dart';
import 'package:uuid/uuid.dart';

import '../models/report.dart';
import 'sharepoint_queue_service.dart';

class ReportService {
  final FirebaseFirestore _db;
  final FirebaseAuth _auth;
  final _uuid = const Uuid();

  static const String collection = 'reports';

  ReportService(this._db, this._auth);

  Future<void> createReport({
    required String reportType,
    required String title,
    required String content,
    required DateTime periodStart,
    required DateTime periodEnd,

    // ✅ NEW
    String programmeId = '',
    String teamId = '',
  }) async {
    final user = _auth.currentUser;
    if (user == null) return;

    final id = _uuid.v4();
    final now = DateTime.now().millisecondsSinceEpoch;

    final report = Report(
      id: id,
      userId: user.uid,
      programmeId: programmeId,
      teamId: teamId,
      reportType: reportType.trim(),
      title: title.trim(),
      content: content.trim(),
      periodStartMs: periodStart.millisecondsSinceEpoch,
      periodEndMs: periodEnd.millisecondsSinceEpoch,
      status: 'draft',
      createdAtMs: now,
      updatedAtMs: now,
      sharePointPath: '/SALSO/Reports/$reportType/${user.uid}/$id',
      sharePointStatus: 'pending',
      sharePointFileUrl: null,
    );

    await _db.collection(collection).doc(id).set(report.toMap());
  }

  Future<void> submitReport(Report report) async {
    // ✅ Ensure programmeId/teamId exists on the report document (helps older drafts)
    final user = _auth.currentUser;
    Map<String, dynamic> patch = {
      'status': 'submitted',
      'sharePointStatus': 'queued',
      'updatedAtMs': DateTime.now().millisecondsSinceEpoch,
    };

    if ((report.programmeId.isEmpty || report.teamId.isEmpty) && user != null) {
      // We try to read user's profile doc by uid (common pattern in this app).
      final userDoc = await _db.collection('users').doc(user.uid).get();
      if (userDoc.exists) {
        final data = userDoc.data() ?? {};
        final p = (data['programmeId'] ?? '').toString();
        final t = (data['teamId'] ?? '').toString();
        if (report.programmeId.isEmpty && p.isNotEmpty) patch['programmeId'] = p;
        if (report.teamId.isEmpty && t.isNotEmpty) patch['teamId'] = t;
      }
    }

    await _db.collection(collection).doc(report.id).update(patch);

    // Keep SharePoint integration queued (demo-safe). [1](https://salsoza-my.sharepoint.com/personal/gerald_salsoza_onmicrosoft_com/Documents/Microsoft%20Copilot%20Chat%20Files/report_service.dart)
    await SharePointQueueService(_db).enqueueReport(
      reportId: report.id,
      sharePointPath: report.sharePointPath,
    );
  }

  Stream<List<Report>> streamMyReports() {
    final user = _auth.currentUser;
    if (user == null) return const Stream.empty();

    return _db
        .collection(collection)
        .where('userId', isEqualTo: user.uid)
        .snapshots()
        .map((s) {
      final list = s.docs.map((d) => Report.fromMap(d.data())).toList();
      list.sort((a, b) => b.createdAtMs.compareTo(a.createdAtMs));
      return list;
    });
  }

  // ✅ Team Leader: reports for the same team (excluding drafts)
  Stream<List<Report>> streamTeamReports(String teamId) {
   